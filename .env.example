# GEMINI_API_KEY: Optional. Only required for running the offline psychometric evaluation tests (scripts/agent_eval.py).
# The main application uses Vertex AI via Firebase Cloud Functions.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public Web API key for the isolated stack-overlord-demo-cog-bridge Firebase app.
VITE_FIREBASE_API_KEY="YOUR_SANDBOX_FIREBASE_WEB_API_KEY"

# Live Firestore rule tests are disabled by default and are sandbox-only.
RUN_LIVE_FIRESTORE_TESTS="false"
